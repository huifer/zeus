{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "zeus/feedback",
  "title": "Zeus Feedback — 用户反馈快照",
  "type": "object",
  "required": ["id", "timestamp", "source", "raw_data", "attribution", "evolution_signal"],
  "properties": {
    "id":        { "type": "string", "pattern": "^FB-\\d{3}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": {
      "type": "string",
      "enum": ["manual", "script", "db_query"],
      "description": "manual = 人工输入；script = 运行采集脚本；db_query = 数据库查询"
    },
    "raw_data": {
      "type": "object",
      "description": "原始反馈数据，自然语言或结构化均可",
      "properties": {
        "text":            { "type": "string", "description": "自然语言描述" },
        "pv":              { "type": ["number", "null"] },
        "uv":              { "type": ["number", "null"] },
        "conversion_rate": { "type": ["number", "null"] },
        "revenue":         { "type": ["number", "null"] },
        "mrr":             { "type": ["number", "null"] },
        "notes":           { "type": "string" }
      }
    },
    "attribution": {
      "type": "array",
      "description": "AI 归因结果：此反馈数据由哪些 task 的行为导致",
      "items": {
        "type": "object",
        "required": ["task_id", "confidence", "reasoning"],
        "properties": {
          "task_id":    { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "reasoning":  { "type": "string", "description": "归因推理链" }
        }
      }
    },
    "evolution_signal": {
      "type": "object",
      "required": ["requires_new_version"],
      "properties": {
        "requires_new_version": { "type": "boolean" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "gap_description": {
          "type": "string",
          "description": "main 版本无法满足的需求缺口描述"
        },
        "ai_reasoning": {
          "type": "string",
          "description": "AI 判断是否需要新版本的理由"
        },
        "suggested_version": { "type": ["string", "null"] }
      }
    },
    "absorbed_into_roadmap": {
      "type": "boolean",
      "default": false,
      "description": "若用户选择不演化，true = 已将需求合并进 main roadmap"
    }
  }
}
