{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "zeus/test-flow",
  "title": "Zeus Test Flow — 平台测试流程",
  "description": "由 generate-tests.sh 调用 AI 生成，位于 .zeus/{version}/tests/{platform}.test.json。描述指定平台的端到端测试场景，面向真实设备/浏览器执行。",
  "type": "object",
  "required": ["platform", "version", "generated_from", "generated_at", "scenarios"],
  "properties": {
    "platform": {
      "type": "string",
      "enum": ["android", "chrome", "ios"],
      "description": "测试目标平台"
    },
    "version": {
      "type": "string",
      "description": "所属 Zeus 版本，如 main / v2"
    },
    "generated_from": {
      "type": "array",
      "items": { "type": "string", "pattern": "^T-\\d{3}$" },
      "description": "生成本测试文件所依据的 task ID 列表"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "platform_defaults": {
      "type": "object",
      "description": "平台级默认配置，可被单个 scenario 覆盖",
      "oneOf": [
        {
          "title": "Android 默认配置",
          "properties": {
            "device":      { "type": "string", "description": "如 emulator-5554 或真机 serial" },
            "app_package": { "type": "string", "description": "如 com.example.app" },
            "activity":    { "type": "string", "description": "如 .MainActivity" }
          }
        },
        {
          "title": "Chrome 默认配置",
          "properties": {
            "base_url":  { "type": "string", "format": "uri" },
            "viewport":  {
              "type": "object",
              "properties": {
                "width":  { "type": "integer" },
                "height": { "type": "integer" }
              }
            },
            "headless": { "type": "boolean", "default": false }
          }
        },
        {
          "title": "iOS 默认配置",
          "properties": {
            "device":    { "type": "string", "description": "如 iPhone 16 Pro 或真机 UDID" },
            "bundle_id": { "type": "string", "description": "如 com.example.app" },
            "scheme":    { "type": "string", "description": "Xcode scheme 名称" },
            "os_version":{ "type": "string", "description": "如 18.0" }
          }
        }
      ]
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "task_id", "story_id", "title", "steps", "passes"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TC-\\d{3}$",
            "description": "测试用例 ID，TC-001 格式"
          },
          "task_id":  { "type": "string", "pattern": "^T-\\d{3}$" },
          "story_id": { "type": "string", "pattern": "^US-\\d{3}$" },
          "title":    { "type": "string", "description": "简洁的用例标题" },
          "description": { "type": "string" },
          "platform_config": {
            "type": "object",
            "description": "覆盖 platform_defaults 的场景级配置，字段同 platform_defaults"
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["seq", "action"],
              "properties": {
                "seq": {
                  "type": "integer",
                  "description": "步骤序号，从 1 开始"
                },
                "action": {
                  "type": "string",
                  "description": "平台原生命令字符串。Android: adb shell ...; Chrome: chrome-cli ...; iOS: xcrun simctl ..."
                },
                "description": {
                  "type": "string",
                  "description": "人类可读的步骤说明"
                },
                "assertion": {
                  "type": "string",
                  "description": "断言命令或表达式，执行后与 expected 比较"
                },
                "expected": {
                  "type": "string",
                  "description": "断言的预期值或模式，支持正则前缀 regex:"
                },
                "timeout_ms": {
                  "type": "integer",
                  "default": 5000,
                  "description": "步骤超时（毫秒）"
                }
              }
            }
          },
          "passes": {
            "type": "boolean",
            "default": false,
            "description": "最近一次执行是否通过"
          },
          "run_at": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "最近一次执行时间"
          },
          "failure_reason": {
            "type": ["string", "null"],
            "description": "最近一次失败原因，passes=true 时为 null"
          }
        }
      }
    }
  }
}
